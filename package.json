{
  "name": "worktree-desk",
  "version": "0.1.0",
  "description": "Worktree Desk desktop app scaffold built with Electrobun, React, TypeScript, Vite, and Tailwind CSS.",
  "scripts": {
    "start": "bun run dev",
    "dev": "vite build && electrobun dev",
    "dev:run": "vite build && electrobun build --env=dev && codesign --force --deep --sign - 'build/dev-macos-arm64/Worktree Desk-dev.app' && open 'build/dev-macos-arm64/Worktree Desk-dev.app'",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run dev\"",
    "hmr": "vite --port 5173",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "vite build && electrobun build --env=canary",
    "build:canary": "vite build && electrobun build --env=canary",
    "build:stable": "vite build && electrobun build --env=stable"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electrobun": "1.18.1",
    "execa": "^9.6.1",
    "lucide-react": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.77.0",
    "tailwind-merge": "^3.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.9"
  }
}
